{
  "name": "ai-companion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "db:migrate:local": "pnpm --filter @ai-companion/api db:migrate:local"
  },
  "devDependencies": {
    "@ai-companion/config": "workspace:*",
    "@eslint/js": "^9.17.0",
    "@next/eslint-plugin-next": "^15.1.3",
    "@types/node": "^20.17.12",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript-eslint": "^8.19.0",
    "typescript": "^5.7.2"
  }
}
